	"item": [
		{
			"name": "Google Collection",
			"item": [
				{
					"name": "Get Google Homepage",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "9c1b1ba9-0dd6-43dc-a5c1-95a5cbc785bf",
								"exec": [
									"pm.test(\"Google responds with correct response code\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Google response time is less than 200ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(200);",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"id": "38765889-87d9-46cc-bd59-d92dd6c7c594",
					"protocolProfileBehavior": {
						"followRedirects": true,
						"disableBodyPruning": true
					},
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": "google.com"
					},
					"response": []
				}
			],
			"id": "73f93db0-1556-4a98-9f95-5e3bbc3d0be8"
